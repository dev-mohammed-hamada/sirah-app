{
  "name": "sirah",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "mobile"
  ],
  "scripts": {
    "start": "npm run start --workspace=mobile",
    "start:backend": "npm run start:dev --workspace=backend",
    "build": "npm run build --workspace=shared && npm run build --workspace=backend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend",
    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:seed": "npm run prisma:seed --workspace=backend"
  }
}
