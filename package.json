{
  "name": "sirah",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "mobile"
  ],
  "scripts": {
    "prepare": "husky",
    "start": "npm run start --workspace=mobile",
    "start:backend": "npm run start:dev --workspace=backend",
    "build": "npm run build --workspace=shared && npm run build --workspace=backend",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "eslint --fix '{backend,shared}/src/**/*.ts' 'backend/test/**/*.ts'",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "test": "npm run test --workspaces --if-present",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend",
    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:seed": "npm run prisma:seed --workspace=backend"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
