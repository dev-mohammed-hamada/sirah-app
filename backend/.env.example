# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sirah

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=7d

# Firebase (Push Notifications)
FIREBASE_ADMIN_KEY=path/to/firebase-admin-key.json

# Storage (S3/R2)
S3_BUCKET=sirah-assets
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Server
PORT=3000
